# ─── FIREBASE ─────────────────────────────────────────────────────────────────
# Firebase Console → Configurações do Projeto → Contas de Serviço → Gerar nova chave
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ─── MERCADO PAGO ──────────────────────────────────────────────────────────────
# https://www.mercadopago.com.br/developers → Suas aplicações → Credenciais
# Use a chave de PRODUÇÃO para cobranças reais, ou TESTE para testar
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── URLS ──────────────────────────────────────────────────────────────────────
# URL do seu frontend (onde o index.html está hospedado)
FRONTEND_URL=https://seudominio.com

# URL deste backend (para o MP enviar webhooks)
BACKEND_URL=https://api.seudominio.com

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3001
